{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["page_component", "components", "state"],
  "properties": {
    "page_component": {
      "type": "string",
      "minLength": 1
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string" },
          "props": { "type": "array" },
          "responsibility": { "type": "string" }
        }
      }
    },
    "state": {
      "type": "object",
      "properties": {
        "fields": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "type": { "type": "string" },
              "default": {}
            }
          }
        }
      }
    },
    "apis": {
      "type": "array",
      "items": { "type": "object" }
    }
  },
  "additionalProperties": true
}
